datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  productId String
  category  String
  quantity  Int
  total     Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}